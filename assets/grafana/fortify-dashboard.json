          "legendFormat": "allowed {{name}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(fortify_rate_limit_denied_total[1m])",
          "legendFormat": "denied {{name}}",
          "refId": "B"
        }
      ],
      "title": "Rate limit /sec",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 15},
      "id": 22,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.99, sum by (le, name) (rate(fortify_rate_limit_wait_seconds_bucket[5m])))",
          "legendFormat": "p99 wait {{name}}",
          "refId": "A"
        }
      ],
      "title": "Rate limit p99 wait",
      "type": "timeseries"
    },
    {
