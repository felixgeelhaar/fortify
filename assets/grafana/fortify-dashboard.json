  "description": "Fortify resilience patterns observability. Imports against any Prometheus datasource scraping fortify_* metrics.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "panels": [],
      "title": "Circuit Breaker",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"color": "green", "index": 0, "text": "Closed"}}, "type": "value"},
            {"options": {"1": {"color": "red", "index": 1, "text": "Open"}}, "type": "value"},
            {"options": {"2": {"color": "yellow", "index": 2, "text": "Half-Open"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        }
      },
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 1},
      "id": 1,
      "options": {"colorMode": "value", "graphMode": "none", "textMode": "auto"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "fortify_circuit_breaker_state",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "CB state by instance",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 1},
      "id": 2,
      "options": {"legend": {"showLegend": true}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(fortify_circuit_breaker_failures_total[1m]) / rate(fortify_circuit_breaker_requests_total[1m])",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "CB failure ratio (1m)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 1},
      "id": 3,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "increase(fortify_circuit_breaker_state_changes_total[5m])",
          "legendFormat": "{{name}} {{from}}->{{to}}",
          "refId": "A"
        }
      ],
      "title": "CB state changes (5m)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 7},
      "id": 200,
      "panels": [],
      "title": "Retry",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 8},
      "id": 11,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.99, sum by (le, name) (rate(fortify_retry_attempts_bucket[5m])))",
          "legendFormat": "p99 {{name}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.50, sum by (le, name) (rate(fortify_retry_attempts_bucket[5m])))",
          "legendFormat": "p50 {{name}}",
          "refId": "B"
        }
      ],
      "title": "Retry attempts per call",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 8},
      "id": 12,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(fortify_retry_successes_total[1m])",
          "legendFormat": "ok {{name}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(fortify_retry_failures_total[1m])",
          "legendFormat": "fail {{name}}",
          "refId": "B"
        }
      ],
      "title": "Retry outcomes /sec",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "id": 300,
