{
  "title": "Fortify overview",
  "uid": "fortify-overview",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["fortify"],
  "timezone": "browser",
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "Circuit breaker state",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "fortify_circuit_breaker_state", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Closed", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "Half-open", "color": "yellow" } } },
            { "type": "value", "options": { "2": { "text": "Open", "color": "red" } } }
          ]
        }
      }
    },
    {
      "type": "graph",
      "title": "CB requests per second (success/failure)",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [
        { "expr": "rate(fortify_circuit_breaker_successes_total[1m])", "legendFormat": "success {{name}}" },
        { "expr": "rate(fortify_circuit_breaker_failures_total[1m])", "legendFormat": "failure {{name}}" }
      ]
    },
    {
      "type": "graph",
      "title": "Retry attempts (histogram)",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(fortify_retry_attempts_bucket[5m])) by (le))", "legendFormat": "p95 attempts" },
        { "expr": "histogram_quantile(0.50, sum(rate(fortify_retry_attempts_bucket[5m])) by (le))", "legendFormat": "p50 attempts" }
      ]
    },
    {
      "type": "graph",
      "title": "Rate limit allow / deny",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "rate(fortify_rate_limit_allowed_total[1m])", "legendFormat": "allowed {{key}}" },
        { "expr": "rate(fortify_rate_limit_denied_total[1m])", "legendFormat": "denied {{key}}" }
      ]
    },
    {
      "type": "graph",
      "title": "Bulkhead active / queued",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "fortify_bulkhead_active", "legendFormat": "active {{name}}" },
        { "expr": "fortify_bulkhead_queued", "legendFormat": "queued {{name}}" }
      ]
    },
    {
      "type": "graph",
      "title": "Timeout duration p95",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(fortify_timeout_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95 (s)" },
        { "expr": "rate(fortify_timeout_exceeded_total[1m])", "legendFormat": "timeouts/s" }
      ]
    }
  ]
}
